<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.pcbuilderapplication.controllers.HomeController"
           stylesheets="@login.css"
           styleClass="root-pane">

    <Pane styleClass="accent-circle-tr" mouseTransparent="true"/>
    <Pane styleClass="accent-circle-bl" mouseTransparent="true"/>

    <VBox styleClass="login-card" alignment="CENTER" spacing="0">

        <fx:include source="header.fxml"/>


        <VBox styleClass="card-content" alignment="CENTER" spacing="24">

            <VBox alignment="CENTER" spacing="6">
                <Label text="Home Page!" styleClass="headline"/>
                <Label text="Select your option below..." styleClass="subheadline"/>
            </VBox>

            <Pane styleClass="divider"/>

            <VBox spacing="14" maxWidth="320" prefWidth="320" alignment="CENTER">
                <Button text="BUILD A PC"
                        styleClass="login-btn"
                        onAction="#goToCatalog"
                        prefWidth="320"/>

                <Button text="SAVED BUILDS"
                        styleClass="login-btn"
                        onAction="#goToSaved"
                        prefWidth="320"/>

                <Button text="LOGOUT"
                        styleClass="login-btn"
                        onAction="#goToLogin"
                        prefWidth="320"/>
            </VBox>

        </VBox>

        <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="8">
            <Pane styleClass="status-dot"/>
            <Label text="System Ready" styleClass="status-text"/>
        </HBox>

    </VBox>

</StackPane>