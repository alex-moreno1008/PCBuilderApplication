<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.pcbuilderapplication.controllers.CatalogController"
           stylesheets="@login.css"
           styleClass="root-pane">

    <Pane styleClass="accent-circle-tr" mouseTransparent="true"/>
    <Pane styleClass="accent-circle-bl" mouseTransparent="true"/>

    <VBox styleClass="login-card"
          alignment="CENTER"
          spacing="0">

        <fx:include source="header.fxml"/>


        <VBox styleClass="card-content" alignment="CENTER" spacing="24">

            <VBox alignment="CENTER" spacing="6">
                <Label text="Select Your PC Parts" styleClass="headline"/>
                <Label text="Choose your components below..." styleClass="subheadline"/>
                <Label text=" WARNING: SOME PARTS MAY NOT BE COMPATIBLE."
                       styleClass="warning-text"/>
            </VBox>

            <Pane styleClass="divider"/>

            <VBox spacing="14" alignment="CENTER" maxWidth="320" prefWidth="320">
                <ComboBox fx:id="cpuBox" promptText="Select CPU" prefWidth="320"/>
                <ComboBox fx:id="motherboardBox" promptText="Select Motherboard" prefWidth="320"/>
                <ComboBox fx:id="gpuBox" promptText="Select GPU" prefWidth="320"/>
                <ComboBox fx:id="ramBox" promptText="Select RAM" prefWidth="320"/>
                <ComboBox fx:id="storageBox" promptText="Select Storage" prefWidth="320"/>
            </VBox>

            <VBox spacing="14" alignment="CENTER" maxWidth="320" prefWidth="320">

                <Button fx:id="fetchGpuBtn"
                        text="Fetch GPUs from Web"
                        onAction="#fetchGpusFromApi"
                        prefWidth="320"
                        styleClass="login-btn"/>

                <HBox spacing="10" alignment="CENTER_LEFT" prefWidth="320">
                    <Label text="BUDGET" styleClass="field-label"/>
                    <TextField fx:id="budgetField"
                               promptText="Enter your budget ($)"
                               styleClass="input-field"
                               HBox.hgrow="ALWAYS"/>
                </HBox>

                <Button text="NEXT"
                        styleClass="login-btn"
                        onAction="#goToSummary"
                        prefWidth="320"/>

                <Button text="BACK HOME"
                        styleClass="login-btn"
                        onAction="#goHome"
                        prefWidth="320"/>

                <Label fx:id="apiStatusLabel" text=""/>

                <Label fx:id="compatibilityLabel"
                       text=""
                       styleClass="warning-text"
                       wrapText="true"
                       maxWidth="320"/>
            </VBox>

        </VBox>

        <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="8">
            <Pane styleClass="status-dot"/>
            <Label text="System Ready" styleClass="status-text"/>
        </HBox>

    </VBox>

</StackPane>
