<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="12.0"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.pcbuilderapplication.controllers.CatalogController"
      prefHeight="450.0" prefWidth="600.0">

    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>

    <children>
        <Label text="Select Your PC Parts"/>

        <ComboBox fx:id="cpuBox" promptText="Select CPU"/>
        <ComboBox fx:id="motherboardBox" promptText="Select Motherboard"/>
        <ComboBox fx:id="gpuBox" promptText="Select GPU"/>
        <ComboBox fx:id="ramBox" promptText="Select RAM"/>
        <ComboBox fx:id="storageBox" promptText="Select Storage"/>

        <Button text="Next" onAction="#goToSummary"/>
        <Button text="Back to Home" onAction="#goHome"/>
    </children>
</VBox>