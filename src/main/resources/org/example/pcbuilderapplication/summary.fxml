<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.pcbuilderapplication.controllers.SummaryController"
           stylesheets="@login.css"
           styleClass="root-pane">

    <Pane styleClass="accent-circle-tr" mouseTransparent="true"/>
    <Pane styleClass="accent-circle-bl" mouseTransparent="true"/>

    <VBox styleClass="login-card"
          alignment="CENTER"
          spacing="0">

        <HBox styleClass="brand-strip" alignment="CENTER_LEFT" spacing="10">
            <Pane styleClass="cpu-icon"/>
            <Label text="PC BUILDER" styleClass="brand-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="v1.0" styleClass="version-label"/>
        </HBox>

        <VBox styleClass="card-content" alignment="CENTER" spacing="24">

            <VBox alignment="CENTER" spacing="6">
                <Label text="Build Summary" styleClass="headline"/>
                <Label text="Review your selected parts..." styleClass="subheadline"/>
            </VBox>

            <Pane styleClass="divider"/>

            <VBox spacing="10" alignment="CENTER_LEFT" maxWidth="320" prefWidth="320">
                <Label fx:id="cpuLabel" text="CPU: " styleClass="subheadline"/>
                <Label fx:id="motherboardLabel" text="Motherboard: " styleClass="subheadline"/>
                <Label fx:id="gpuLabel" text="GPU: " styleClass="subheadline"/>
                <Label fx:id="ramLabel" text="RAM: " styleClass="subheadline"/>
                <Label fx:id="storageLabel" text="Storage: " styleClass="subheadline"/>

                <Pane styleClass="divider"/>

                <Label fx:id="totalLabel" text="Total: $0" styleClass="headline"/>
            </VBox>

            <VBox spacing="14" alignment="CENTER" maxWidth="320" prefWidth="320">
                <Button text="BACK TO CATALOG"
                        styleClass="login-btn"
                        onAction="#goToCatalog"
                        prefWidth="320"/>

                <Button text="SAVE BUILD"
                        styleClass="login-btn"
                        onAction="#saveBuild"
                        prefWidth="320"/>

                <Button text="HOME"
                        styleClass="login-btn"
                        onAction="#goHome"
                        prefWidth="320"/>
            </VBox>

        </VBox>

        <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="8">
            <Pane styleClass="status-dot"/>
            <Label text="System Ready" styleClass="status-text"/>
        </HBox>

    </VBox>

</StackPane>